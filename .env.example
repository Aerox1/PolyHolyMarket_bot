# ════════════════════════════════════════════════════════════════════
#  Polymarket Trading Bot — environment configuration
#  Copy to .env and fill in.  NEVER commit .env.
# ════════════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────
# Bot token from @BotFather.  SECRET.  Rotate if ever exposed (/revoke).
TELEGRAM_BOT_TOKEN=
# Optional comma-separated Telegram user IDs allowed during private beta.
# Leave empty to allow everyone (each user only ever sees their own data).
TELEGRAM_ALLOWED_USERS=

# ── Encryption ───────────────────────────────────────────
# 32-byte urlsafe-base64 Fernet key used to encrypt user private keys AT REST.
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠ The bot + worker need this. The DASHBOARD must run WITHOUT it (cannot decrypt keys).
# ⚠ Losing this key makes all stored wallet keys unrecoverable. Back it up in a secrets manager.
ENCRYPTION_KEY=
# Optional older keys for rotation (comma-separated), newest first excluded:
ENCRYPTION_KEY_OLD=

# ── Database ─────────────────────────────────────────────
# Sync URL (dashboard, worker, alembic):
DATABASE_URL=postgresql+psycopg://pmbot:pmbot@localhost:5432/pmbot
# Async URL (bot).  If empty, derived from DATABASE_URL by swapping the driver.
DATABASE_URL_ASYNC=postgresql+asyncpg://pmbot:pmbot@localhost:5432/pmbot

# ── Admin dashboard ──────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8877
# Secret used to sign dashboard session cookies.
SESSION_SECRET=
# Set to true in production (behind TLS) so the session cookie is Secure-only.
DASHBOARD_COOKIE_SECURE=false
# Bootstrap the first admin on startup if the admins table is empty.
# Generate the hash:  python -m core.crypto hash-password 'your-password'
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD_HASH=

# ── Polymarket APIs ──────────────────────────────────────
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
CHAIN_ID=137

# ── Mini App (Telegram Web App) ──────────────────────────
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8888
# Public HTTPS URL of the Mini App — set this as the Web App URL in @BotFather.
WEBAPP_BASE_URL=
# Reject initData older than this many seconds (replay protection).
INITDATA_MAX_AGE_SECONDS=3600

# ── Gemini (category card images) ────────────────────────
# Create at https://aistudio.google.com/apikey (enables the API automatically;
# image models need billing on). SECRET. Lives in the bot/webapp, NOT the dashboard.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Estimated USD per generated image (for budget accounting).
GEMINI_IMAGE_COST_USD=0.04
# Default weekly image budget (USD). Live value is editable in the admin dashboard.
GEMINI_WEEKLY_BUDGET_USD=10
CARDS_DIR=data/cards

# ── Behaviour ────────────────────────────────────────────
DEFAULT_LANGUAGE=en
# Polymarket signup URL shown by the "Create account" button.
POLYMARKET_SIGNUP_URL=https://polymarket.com
LOG_LEVEL=INFO
